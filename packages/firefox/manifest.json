{
  "manifest_version": 3,
  "name": "Hauberk",
  "version": "0.3.1",
  "description": "Automatically redirects npmjs.com package links to npmx.dev.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "https://*.npmjs.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_redirect",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "npmx-redirector@santosvilanculos.github.io",
      "data_collection_permissions": {
        "data_access": [],
        "data_use": "This add-on does not collect or transmit any user data."
      }
    }
  }
}
